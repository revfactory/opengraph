# OG Unfurl 서비스 환경변수 예시
# 통합 아키텍처(_workspace/02) 확정값을 config.ts 기본값으로 반영 → 아무 것도 설정하지 않아도 기동됨.
#
# 두 가지 기동 모드:
#   (A) 로컬 인메모리 — REDIS_URL / DATABASE_URL 를 "설정하지 않음". 외부 의존 0, npm run dev.
#   (B) 실 백엔드    — REDIS_URL / DATABASE_URL 를 설정. ioredis / pg 어댑터가 자동 선택됨.
#                      docker-compose 는 아래 값을 서비스 이름으로 주입한다.
#
# ※ 선택 규칙: REDIS_URL/DATABASE_URL 의 "존재"로 어댑터를 고른다. 미설정 → 인메모리(graceful).
#    접속 실패 시에도 인메모리로 강등되어 서비스는 항상 뜬다.

# ── 서버 ──
PORT=8080

# ── 실 백엔드 선택(설정 시 활성화. 로컬 인메모리로 쓰려면 주석 처리/삭제) ──
# 로컬 도커: docker compose up 이 아래를 자동 주입하므로 수동 설정 불필요.
# 로컬에서 직접 컨테이너만 띄워 붙일 때 예시:
REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgres://ogsvc:ogsvc@127.0.0.1:5432/ogsvc

# ── docker-compose 자격증명(compose 가 이 값으로 postgres 를 초기화) ──
POSTGRES_USER=ogsvc
POSTGRES_PASSWORD=ogsvc
POSTGRES_DB=ogsvc

# ── 타임아웃 예산 (platform §2-3 / crawl §4.2) ──
OG_SYNC_BUDGET_MS=3000       # 동기 응답 예산. 초과 시 202 + job_id 로 큐 승격
OG_CONNECT_TIMEOUT_MS=3000   # TCP 연결 타임아웃
OG_HEADERS_TIMEOUT_MS=5000   # 헤더 수신 타임아웃
OG_TOTAL_TIMEOUT_MS=8000     # 페치 전체 타임아웃
OG_MAX_REDIRECT_HOPS=10      # 리다이렉트 홉 상한

# ── 페치 상한 (crawl §4.2) ──
OG_MAX_BODY_BYTES=2097152

# ── 허용목록 (crawl §4.1) ──
OG_ALLOWED_SCHEMES=http,https
OG_ALLOWED_PORTS=80,443,8080,8443

# ── 완성도 임계 (§1-4 확정: ok ⟺ ≥0.66) ──
OG_COMPLETE_THRESHOLD=0.66

# ── 캐시 TTL (platform §3-3) ──
OG_DEFAULT_TTL_SEC=86400
OG_MAP_TTL_SEC=604800
OG_SHORT_MAP_TTL_SEC=2592000
OG_NEG_TTL_4XX_SEC=1800
OG_NEG_TTL_5XX_SEC=300

# ── 헤드리스 (crawl §1.3) ──
OG_MAX_HEADLESS_CONCURRENCY=4
OG_HEADLESS_NAV_TIMEOUT_MS=10000

# ── 관측 ──
OG_METRICS_ENABLED=true
